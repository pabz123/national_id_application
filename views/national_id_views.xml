<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- =============== SEQUENCE FOR AUTO-NUMBERING =============== -->
    <data noupdate="1">
        <record id="seq_national_id_application" model="ir.sequence">
            <field name="name">National ID Application</field>
            <field name="code">national.id.application</field>
            <field name="prefix">NID/%(year)s/</field>
            <field name="padding">4</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>
    </data>

    <!-- =============== LIST VIEW =============== -->
    <record id="view_national_id_application_list" model="ir.ui.view">
        <field name="name">national.id.application.list</field>
        <field name="model">national.id.application</field>
        <field name="arch" type="xml">
            <list string="National ID Applications">
                <field name="name"/>
                <field name="full_name"/>
                <field name="age"/>
                <field name="phone"/>
                <field name="district_name"/>
                <field name="create_date"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <!-- =============== FORM VIEW =============== -->
    <record id="view_national_id_application_form" model="ir.ui.view">
        <field name="name">national.id.application.form</field>
        <field name="model">national.id.application</field>
        <field name="arch" type="xml">
            <form string="National ID Application">
                <header>
                    <!-- Workflow Buttons -->
                    <button name="action_submit_stage1"
                        string="Submit for Stage 1"
                        type="object"
                        class="btn-primary"
                        groups="national_id_application.group_national_id_officer,national_id_application.group_national_id_admin"
                        invisible="state != 'new'"/>
                    
                    <button name="action_open_stage1_approval_wizard"
                        string="Approve Stage 1"
                        type="object"
                        class="btn-success"
                        groups="national_id_application.group_national_id_stage1_approver,national_id_application.group_national_id_admin"
                        invisible="state != 'stage1_review'"/>
                    
                    <button name="action_submit_stage2"
                        string="Submit for Stage 2"
                        type="object"
                        class="btn-primary"
                        groups="national_id_application.group_national_id_stage1_approver,national_id_application.group_national_id_admin"
                        invisible="state != 'stage1_approved'"/>
                    
                    <button name="action_open_stage2_approval_wizard"
                        string="Approve Stage 2 (Final)"
                        type="object"
                        class="btn-success"
                        groups="national_id_application.group_national_id_stage2_approver,national_id_application.group_national_id_admin"
                        invisible="state != 'stage2_review'"/>
                    
                    <button name="action_open_rejection_wizard"
                        string="Reject"
                        type="object"
                        class="btn-danger"
                        groups="national_id_application.group_national_id_stage1_approver,national_id_application.group_national_id_stage2_approver,national_id_application.group_national_id_admin"
                        invisible="state in ['approved', 'rejected']"/>
                    
                    <button name="action_reset_to_new"
                        string="Reset to New"
                        type="object"
                        groups="national_id_application.group_national_id_admin"
                        invisible="state != 'rejected'"/>
                    
                    <field name="state" widget="statusbar"
                        statusbar_visible="new,stage1_review,stage1_approved,stage2_review,approved"/>
                </header>
                
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    
                    <group>
                        <group string="Personal Information">
                            <field name="full_name"/>
                            <field name="date_of_birth"/>
                            <field name="age" readonly="1"/>
                            <field name="gender"/>
                            <field name="nationality_id"/>
                            <field name="existing_nin"/>
                        </group>
                        
                        <group string="Contact Information">
                            <field name="district_name"/>
                            <field name="district_id" domain="[('country_id', '=', nationality_id)]" readonly="1"/>
                            <field name="phone"/>
                            <field name="email"/>
                        </group>
                    </group>

                    <group string="Workflow Tracking">
                        <group>
                            <field name="create_uid" string="Created By" readonly="1"/>
                            <field name="create_date" readonly="1"/>
                        </group>
                        <group>
                            <field name="current_stage_label" readonly="1"/>
                            <field name="pending_reviewer_ids" widget="many2many_tags" readonly="1"/>
                        </group>
                    </group>
                    
                    <notebook>
                        <page string="Attachments">
                            <group>
                                <group string="Passport Photo">
                                    <field name="photo" widget="image" class="oe_avatar"/>
                                    <field name="photo_filename" invisible="1"/>
                                </group>
                                <group string="LC Reference Letter">
                                    <field name="lc_letter" filename="lc_letter_filename"/>
                                    <field name="lc_letter_filename" invisible="1"/>
                                </group>
                            </group>
                        </page>
                        
                        <page string="Approval Information" invisible="state == 'new'">
                            <group>
                                <group string="Stage 1 Approval">
                                    <field name="stage1_identity_verified" readonly="state not in ['stage1_review']"/>
                                    <field name="stage1_documents_verified" readonly="state not in ['stage1_review']"/>
                                    <field name="stage1_review_notes" readonly="state not in ['stage1_review']"/>
                                    <field name="stage1_incomplete_override_reason" readonly="1" invisible="not stage1_incomplete_override_reason"/>
                                    <field name="stage1_approver_id"/>
                                    <field name="stage1_approval_date"/>
                                </group>
                                <group string="Stage 2 Approval">
                                    <field name="stage2_data_crosschecked" readonly="state not in ['stage2_review']"/>
                                    <field name="stage2_review_notes" readonly="state not in ['stage2_review']"/>
                                    <field name="stage2_incomplete_override_reason" readonly="1" invisible="not stage2_incomplete_override_reason"/>
                                    <field name="stage2_approver_id"/>
                                    <field name="stage2_approval_date"/>
                                </group>
                            </group>
                            <group string="Rejection Details" invisible="state != 'rejected'">
                                <field name="rejection_category" readonly="1"/>
                                <field name="rejection_reason" readonly="1"/>
                                <field name="rejected_by_id" readonly="1"/>
                                <field name="rejected_on" readonly="1"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                
                <!-- Chatter for logging approval messages -->
                <chatter>
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </chatter>
            </form>
        </field>
    </record>

    <!-- =============== SEARCH VIEW =============== -->
