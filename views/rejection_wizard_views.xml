<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_national_id_rejection_wizard_form" model="ir.ui.view">
        <field name="name">national.id.rejection.wizard.form</field>
        <field name="model">national.id.rejection.wizard</field>
        <field name="arch" type="xml">
            <form string="Reject Application">
                <group>
                    <field name="application_id" readonly="1"/>
                    <field name="rejection_category"/>
                    <field name="rejection_reason" placeholder="Enter why this application is being rejected..."/>
                </group>
                <footer>
                    <button name="action_confirm_rejection"
                            string="Confirm Rejection"
                            type="object"
                            class="btn-danger"/>
                    <button string="Cancel"
                            class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
