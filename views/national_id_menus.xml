<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Main menu item in the App Drawer -->
    <menuitem id="menu_national_id_root"
        name="National ID"
        groups="national_id_application.group_national_id_officer,national_id_application.group_national_id_stage1_approver,national_id_application.group_national_id_stage2_approver,national_id_application.group_national_id_admin"
        sequence="10"/>

    <!-- Submenu: Applications -->
    <menuitem id="menu_national_id_applications"
        name="Applications"
        parent="menu_national_id_root"
        groups="national_id_application.group_national_id_officer,national_id_application.group_national_id_stage1_approver,national_id_application.group_national_id_stage2_approver,national_id_application.group_national_id_admin"
        sequence="10"/>

    <!-- Submenu: Configuration -->
    <menuitem id="menu_national_id_config"
        name="Configuration"
        parent="menu_national_id_root"
        groups="national_id_application.group_national_id_admin"
        sequence="100"/>

    <!-- Action to open the list view -->
    <record id="action_national_id_application" model="ir.actions.act_window">
        <field name="name">ID Applications</field>
        <field name="res_model">national.id.application</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No applications yet. Citizens can apply via the web portal.
            </p>
        </field>
    </record>

    <!-- Link the action to the menu -->
    <menuitem id="menu_national_id_application_list"
        name="All Applications"
        parent="menu_national_id_applications"
        action="action_national_id_application"
        groups="national_id_application.group_national_id_officer,national_id_application.group_national_id_stage1_approver,national_id_application.group_national_id_stage2_approver,national_id_application.group_national_id_admin"
        sequence="10"/>

    <!-- Districts menu -->
    <menuitem id="menu_district_list"
        name="Districts"
        parent="menu_national_id_config"
        action="action_district"
        groups="national_id_application.group_national_id_admin"
        sequence="10"/>

</odoo>
