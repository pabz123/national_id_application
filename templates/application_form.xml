<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- =============== APPLICATION FORM TEMPLATE =============== -->
    <template id="application_form_template" name="National ID Application Form">
        <t t-call="web.frontend_layout">
            <div id="wrap" class="oe_structure">
                <div class="container mt-5 mb-5">
                    <div class="row">
                        <div class="col-md-8 offset-md-2">
                            <h1 class="text-center mb-4">National ID Application</h1>
                            <p class="text-center text-muted mb-5">
                                Please fill in all required fields accurately.
                            </p>

                            <div class="alert alert-danger" t-if="error_message" role="alert">
                                <t t-esc="error_message"/>
                                <div class="small mt-2">
                                    Please check your entries and re-upload required files before submitting again.
                                </div>
                            </div>
                            
                            <form action="/national-id/submit" method="POST" enctype="multipart/form-data" class="o_mark_required" id="application_form">
                                
                                <!-- Personal Information -->
                                <h4 class="mt-4 mb-3">Personal Information</h4>
                                
                                <div class="mb-3">
                                    <label for="full_name" class="form-label">Full Name *</label>
                                    <input type="text" class="form-control" id="full_name" name="full_name" required="required"
                                           t-att-value="form_data.get('full_name', '')"/>
                                </div>
                                
                                <div class="mb-3">
                                    <label for="date_of_birth" class="form-label">Date of Birth *</label>
                                    <input type="date" class="form-control" id="date_of_birth" name="date_of_birth" required="required"
                                           onchange="validateDateOfBirth()" t-att-value="form_data.get('date_of_birth', '')"/>
                                    <small class="text-muted">Cannot be a future date</small>
                                    <div id="dob-error" class="invalid-feedback" style="display: none;"></div>
                                </div>
                                
                                <div class="mb-3">
                                    <label for="gender" class="form-label">Gender *</label>
                                    <select class="form-select" id="gender" name="gender" required="required">
                                        <option value="">-- Select Gender --</option>
                                        <option value="male" t-att-selected="form_data.get('gender') == 'male' and 'selected' or None">Male</option>
                                        <option value="female" t-att-selected="form_data.get('gender') == 'female' and 'selected' or None">Female</option>
                                        <option value="other" t-att-selected="form_data.get('gender') == 'other' and 'selected' or None">Other</option>
                                    </select>
                                </div>
                                
                                <div class="mb-3">
                                    <label for="nationality_id" class="form-label">Nationality *</label>
                                    <select class="form-select" id="nationality_id" name="nationality_id" required="required" onchange="filterDistricts()">
                                        <option value="">-- Select Country --</option>
                                        <t t-foreach="countries" t-as="country">
                                            <option t-att-value="country.id"
                                                    t-att-data-country-id="country.id"
                                                    t-att-selected="str(country.id) == str(form_data.get('nationality_id') or '') and 'selected' or None">
                                                <t t-esc="country.name"/>
                                            </option>
                                        </t>
                                    </select>
                                </div>
                                
                                <div class="mb-3">
                                    <label for="existing_nin" class="form-label">Existing NIN (if renewal/replacement)</label>
                                    <input type="text" class="form-control" id="existing_nin" name="existing_nin" placeholder="CM00000000000"
                                           t-att-value="form_data.get('existing_nin', '')"/>
                                    <small class="form-text text-muted">National Identification Number - Fill only if renewing or replacing lost ID</small>
                                </div>
                                
                                <!-- Contact Information -->
                                <h4 class="mt-5 mb-3">Contact Information</h4>
                                
                                <div class="mb-3">
                                    <label for="district_name" class="form-label">District of Origin *</label>
                                    <input type="text" class="form-control" id="district_name" name="district_name" list="district_list" required="required"
                                           t-att-value="form_data.get('district_name', '')"/>
                                    <datalist id="district_list">
                                        <t t-foreach="districts" t-as="district">
                                            <option t-att-value="district.name" 
                                                    t-att-data-country-id="district.country_id.id"
                                                    t-att-data-district-id="district.id">
                                            </option>
                                        </t>
                                    </datalist>
                                    <small class="text-muted">Select from the list or type your district name if not available</small>
                                    <input type="hidden" id="district_id" name="district_id" t-att-value="form_data.get('district_id', '')"/>
                                </div>
                                
                                <div class="mb-3">
                                    <label for="phone" class="form-label">Phone Number *</label>
                                    <input type="tel" id="phone" name="phone" required="required" placeholder="+256700000000"
                                           t-attf-class="form-control #{'is-invalid' if field_errors.get('phone') else ''}"
                                           t-att-value="form_data.get('phone', '')"/>
                                    <div class="invalid-feedback d-block" t-if="field_errors.get('phone')">
                                        <t t-esc="field_errors.get('phone')"/>
                                    </div>
                                    <small class="text-muted">Format: +256700000000</small>
                                </div>
                                
                                <div class="mb-3">
                                    <label for="email" class="form-label">Email Address *</label>
                                    <input type="email" id="email" name="email" required="required" placeholder="your.email@example.com"
                                           t-attf-class="form-control #{'is-invalid' if field_errors.get('email') else ''}"
                                           t-att-value="form_data.get('email', '')"/>
                                    <div class="invalid-feedback d-block" t-if="field_errors.get('email')">
                                        <t t-esc="field_errors.get('email')"/>
                                    </div>
                                </div>
                                
                                <!-- Required Documents -->
                                <h4 class="mt-5 mb-3">Required Documents</h4>
                                
                                <div class="mb-3">
                                    <label for="photo" class="form-label">Passport Photo *</label>
                                    <input type="file" class="form-control" id="photo" name="photo" accept="image/*" required="required"/>
                                    <small class="form-text text-muted">Upload a clear passport-sized photo.</small>
                                </div>
                                
                                <div class="mb-3">
                                    <label for="lc_letter" class="form-label">LC Reference Letter *</label>
                                    <input type="file" class="form-control" id="lc_letter" name="lc_letter" accept=".pdf,.doc,.docx,image/*" required="required"/>
                                    <small class="form-text text-muted">Upload the reference letter from your Local Council.</small>
                                </div>
                                
                                <!-- Submit Button -->
                                <div class="text-center mt-5">
                                    <button type="submit" class="btn btn-primary btn-lg">Submit Application</button>
                                </div>
                            </form>
                            
                            <!-- JavaScript for dynamic district filtering and age validation -->
                            <script>
                                var allDistrictOptions = Array.from(
                                    document.querySelectorAll('#district_list option')
                                ).map(function(option) {
                                    return {
                                        value: option.value,
                                        countryId: option.getAttribute('data-country-id'),
                                        districtId: option.getAttribute('data-district-id'),
                                    };
                                });

                                // Filter districts based on selected country
                                function filterDistricts() {
                                    var nationalitySelect = document.getElementById('nationality_id');
                                    var districtInput = document.getElementById('district_name');
                                    var districtIdInput = document.getElementById('district_id');
                                    var datalist = document.getElementById('district_list');
                                    var selectedCountry = nationalitySelect.value;
                                    
                                    // Clear district input and hidden ID
                                    districtInput.value = '';
                                    districtIdInput.value = '';
                                    
                                    // Rebuild datalist options for selected country
                                    datalist.innerHTML = '';
                                    allDistrictOptions.forEach(function(item) {
                                        if (!selectedCountry || item.countryId === selectedCountry) {
                                            var option = document.createElement('option');
                                            option.value = item.value;
                                            option.setAttribute('data-district-id', item.districtId || '');
                                            datalist.appendChild(option);
                                        }
                                    });
                                }
                                
                                // Update hidden district_id when user selects from datalist
                                document.getElementById('district_name').addEventListener('input', function() {
                                    var districtName = this.value;
                                    var datalist = document.getElementById('district_list');
                                    var districtIdInput = document.getElementById('district_id');
                                    
                                    // Try to find matching district ID
                                    districtIdInput.value = '';
                                    var options = datalist.options;
                                    for (var i = 0; i &lt; options.length; i++) {
                                        if (options[i].value === districtName) {
                                            var districtId = options[i].getAttribute('data-district-id');
                                            if (districtId) {
                                                districtIdInput.value = districtId;
                                            }
                                            break;
                                        }
                                    }
                                });
                                
                                // Instant validation for date of birth
                                function validateDateOfBirth() {
                                    var dobInput = document.getElementById('date_of_birth');
                                    var dobError = document.getElementById('dob-error');
                                    var dob = new Date(dobInput.value);
                                    var today = new Date();
                                    
                                    // Set today to start of day for fair comparison
                                    today.setHours(0, 0, 0, 0);
                                    dob.setHours(0, 0, 0, 0);
                                    
                                    // Clear previous error state
                                    dobInput.classList.remove('is-invalid');
                                    dobError.style.display = 'none';
                                    
                                    if (!dobInput.value) {
                                        return; // Don't show error if empty (required attribute will handle it)
                                    }
                                    
                                    // Check if date is in the future
                                    if (dob > today) {
                                        dobInput.classList.add('is-invalid');
                                        dobError.textContent = '❌ Date of birth cannot be in the future!';
                                        dobError.style.display = 'block';
                                        return false;
                                    }
                                    
                                    // Check if date is more than 120 years ago
                                    var age = today.getFullYear() - dob.getFullYear();
                                    if (age > 120) {
                                        dobInput.classList.add('is-invalid');
                                        dobError.textContent = '⚠️ Please verify the date of birth. The date entered suggests an age over 120 years.';
                                        dobError.style.display = 'block';
                                        return false;
                                    }
                                    
                                    // If valid, show success indicator
                                    dobInput.classList.add('is-valid');
                                    return true;
                                }
                                
                                // Also validate on form submission
                                document.getElementById('application_form').addEventListener('submit', function(e) {
                                    if (validateDateOfBirth() === false) {
                                        e.preventDefault();
                                        return false;
                                    }
                                });
                            </script>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>
    
    <!-- =============== SUCCESS PAGE TEMPLATE =============== -->
    <template id="application_success_template" name="Application Success">
        <t t-call="web.frontend_layout">
            <div id="wrap" class="oe_structure">
                <div class="container mt-5 mb-5">
                    <div class="row">
                        <div class="col-md-6 offset-md-3 text-center">
                            <div class="alert alert-success p-5">
                                <h1 class="mb-4">✓ Application Submitted Successfully!</h1>
                                <h3 class="mb-4">Your Reference Number:</h3>
                                <h2 class="text-primary mb-4">
                                    <strong t-esc="reference"/>
                                </h2>
                                <p class="lead">
                                    Please save this reference number for tracking your application.
                                </p>
                                <p class="text-muted">
                                    You will be notified once your application is processed.
                                </p>
                                <a href="/national-id/apply" class="btn btn-primary mt-4">Submit Another Application</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

</odoo>
